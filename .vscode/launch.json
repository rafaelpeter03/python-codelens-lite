{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/python-codelens-lite"
      ],
      "outFiles": [
        "${workspaceFolder}/python-codelens-lite/dist/**/*.js"
      ],
      "preLaunchTask": "npm: watch"
    }
  ]
}
