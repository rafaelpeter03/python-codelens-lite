{
  "name": "python-codelens-lite",
  "displayName": "Python CodeLens Lite",
  "icon": "icon.png",
  "description": "Lightweight, configurable CodeLens for Python (references, implementations, scoped imports).",
  "version": "0.1.0",
  "publisher": "rafaelptr",
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "python",
    "codelens",
    "references"
  ],
  "activationEvents": [
    "onLanguage:python"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pythonCodeLensLite.toggle",
        "title": "%command.toggle.title%"
      },
      {
        "command": "pythonCodeLensLite.refresh",
        "title": "%command.refresh.title%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "pythonCodeLensLite.enable": {
          "type": "boolean",
          "default": true,
          "description": "%config.enable.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.targets.classes": {
          "type": "boolean",
          "default": true,
          "description": "%config.targets.classes.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.targets.methods": {
          "type": "boolean",
          "default": true,
          "description": "%config.targets.methods.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.targets.functions": {
          "type": "boolean",
          "default": true,
          "description": "%config.targets.functions.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.targets.moduleVariables": {
          "type": "boolean",
          "default": false,
          "description": "%config.targets.moduleVariables.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.targets.imports.project": {
          "type": "boolean",
          "default": false,
          "description": "%config.targets.imports.project.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.targets.imports.venv": {
          "type": "boolean",
          "default": false,
          "description": "%config.targets.imports.venv.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.targets.imports.stdlib": {
          "type": "boolean",
          "default": false,
          "description": "%config.targets.imports.stdlib.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.targets.imports.global": {
          "type": "boolean",
          "default": false,
          "description": "%config.targets.imports.global.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.references.filterImports": {
          "type": "boolean",
          "default": true,
          "description": "%config.references.filterImports.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.references.filterDefinitions": {
          "type": "boolean",
          "default": true,
          "description": "%config.references.filterDefinitions.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.references.filterSelf": {
          "type": "boolean",
          "default": false,
          "description": "%config.references.filterSelf.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.references.minCount": {
          "type": "number",
          "default": 0,
          "description": "%config.references.minCount.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.references.showZero": {
          "type": "boolean",
          "default": true,
          "description": "%config.references.showZero.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.lenses.showImplementations": {
          "type": "boolean",
          "default": true,
          "description": "%config.lenses.showImplementations.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.clickAction": {
          "type": "string",
          "enum": [
            "peek",
            "reveal"
          ],
          "default": "peek",
          "description": "%config.clickAction.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.performance.debounceMs": {
          "type": "number",
          "default": 250,
          "description": "%config.performance.debounceMs.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.performance.maxFileSizeKB": {
          "type": "number",
          "default": 512,
          "description": "%config.performance.maxFileSizeKB.description%",
          "scope": "resource"
        },
        "pythonCodeLensLite.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/.venv/**",
            "**/venv/**",
            "**/site-packages/**",
            "**/__pycache__/**"
          ],
          "description": "%config.exclude.description%",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile -- --production",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@types/vscode": "1.96.0",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vscode/vsce": "3.9.1",
    "esbuild": "0.28.0",
    "eslint": "10.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  },
  "engines": {
    "vscode": "^1.96.0"
  }
}
